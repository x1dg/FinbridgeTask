@model List<Finbridge.Web.ViewModels.BalanceHistoryViewModel>

@{
    ViewData["Title"] = "История баланса";
}

<div class="container mt-4">
    <h1 class="mb-4">История изменений баланса</h1>
    <a href="@Url.Action("Index", "Home")" class="btn btn-secondary mb-3">Назад к пользователям</a>
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Изменение</th>
                <th>Новый баланс</th>
                <th>Дата и время</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                for (int i = 0; i < Model.Count; i++)
                {
                    var item = Model[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@item.AmountChanged</td>
                        <td>@item.NewBalance</td>
                        <td>@item.ChangedAt.ToString("g")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">История изменений не найдена</td>
                </tr>
            }
        </tbody>
    </table>
</div>