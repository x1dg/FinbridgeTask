@page "/balance-history/{userId:int}"
@inject IRequestDispatcher Dispatcher
@inject IMessageService MessageService
@inject NavigationManager Navigation

<PageTitle>История баланса</PageTitle>

<Space Style="margin-bottom: 16px;" Size="@("middle")">
    <SpaceItem>
        <Button Icon="@IconType.Outline.ArrowLeft" OnClick="@(() => Navigation.NavigateTo("/"))">
            Назад
        </Button>
    </SpaceItem>
    <SpaceItem>
        <Title Level="2" Style="margin: 0;">История баланса — пользователь #@UserId</Title>
    </SpaceItem>
    <SpaceItem>
        <Button Icon="@IconType.Outline.Reload" OnClick="LoadHistoryAsync">
            Обновить
        </Button>
    </SpaceItem>
</Space>

@if (_loading)
{
    <Spin Tip="Загрузка истории..." Size="large">
        <div style="min-height: 200px;"></div>
    </Spin>
}
else
{
    <Table TItem="HistoryRow"
           DataSource="@_history"
           Size="TableSize.Middle"
           Bordered
           Loading="_loading">
        <ChildContent>
            <Column TData="int" Title="#" Width="80">
                @context.Index
            </Column>
            <Column TData="decimal" Title="Изменение">
                @context.Row.AmountChanged.ToString("N2")
            </Column>
            <Column TData="decimal" Title="Новый баланс">
                <Tag Color="@(context.Row.NewBalance >= 0 ? "green" : "red")">
                    @context.Row.NewBalance.ToString("N2")
                </Tag>
            </Column>
            <Column TData="DateTime" Title="Дата и время">
                @context.Row.ChangedAt.ToLocalTime().ToString("g")
            </Column>
        </ChildContent>
    </Table>
}

@code {
    [Parameter] public int UserId { get; set; }

    private IReadOnlyList<HistoryRow> _history = Array.Empty<HistoryRow>();
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        _loading = true;
        try
        {
            var items = await Dispatcher.SendAsync(new GetBalanceHistoryQuery(UserId, Limit: 20));
            _history = items.Select((r, i) => new HistoryRow(r, i + 1)).ToList();
        }
        catch (Exception ex)
        {
            await MessageService.Error($"Не удалось загрузить историю: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed record HistoryRow(BalanceHistoryResponse Row, int Index);
}
