@page "/"
@inject IRequestDispatcher Dispatcher
@inject IMessageService MessageService

<PageTitle>Пользователи</PageTitle>

<Space Style="margin-bottom: 16px;" Size="@("large")">
    <SpaceItem>
        <Title Level="2" Style="margin: 0;">Пользователи</Title>
    </SpaceItem>
    <SpaceItem>
        <Button Type="primary" Icon="@IconType.Outline.Plus" OnClick="ShowCreateModal">
            Создать пользователя
        </Button>
    </SpaceItem>
    <SpaceItem>
        <Button Icon="@IconType.Outline.Reload" OnClick="LoadUsersAsync">
            Обновить
        </Button>
    </SpaceItem>
</Space>

@if (_loading)
{
    <Spin Tip="Загрузка пользователей..." Size="large">
        <div style="min-height: 200px;"></div>
    </Spin>
}
else
{
    <Table TItem="UserResponse"
           DataSource="@_users"
           Size="TableSize.Middle"
            Bordered
           Loading="_loading">
        <ChildContent>
            <Column TData="int" Title="ID" DataIndex="@nameof(UserResponse.Id)" Width="80" />
            <Column TData="string" Title="ФИО" DataIndex="@nameof(UserResponse.FullName)" />
            <Column TData="string" Title="Место рождения" DataIndex="@nameof(UserResponse.PlaceOfBirth)" />
            <Column TData="DateTime" Title="Дата рождения" DataIndex="@nameof(UserResponse.DateOfBirth)">
                @context.DateOfBirth.ToString("d")
            </Column>
            <Column TData="decimal" Title="Баланс" DataIndex="@nameof(UserResponse.Balance)" Width="140">
                <Tag Color="@(context.Balance >= 0 ? "green" : "red")">
                    @context.Balance.ToString("N2")
                </Tag>
            </Column>
            <Column TData="UserResponse" Title="Действия" Width="280">
                <Button Size="small" Type="@ButtonType.Link" OnClick="@(() => ShowBalanceModal(context))">
                    Изменить баланс
                </Button>
                <Button Size="small" Type="@ButtonType.Link" OnClick="@(() => NavigateToHistory(context.Id))">
                    История баланса
                </Button>
            </Column>
        </ChildContent>
    </Table>
}

<Modal Title="Создание пользователя"
       Visible="@_createModalVisible"
       OnOk="@HandleCreateAsync"
       OnCancel="@(() => _createModalVisible = false)"
       ConfirmLoading="@_createLoading">
    <Form Model="@_newUser" Layout="@FormLayout.Vertical">
        <FormItem Label="ФИО" Required>
            <Input @bind-Value="@_newUser.FullName" Placeholder="Иванов Иван Иванович" />
        </FormItem>
        <FormItem Label="Дата рождения" Required>
            <DatePicker TValue="DateTime?"
                        @bind-Value="@_newUser.DateOfBirth"
                        Format="dd.MM.yyyy"
                        Placeholder="@("Выберите дату")"
                        Style="width: 100%;" />
        </FormItem>
        <FormItem Label="Место рождения" Required>
            <AutoComplete @bind-Value="@_newUser.PlaceOfBirth"
                          Options="@_cityOptions"
                          Placeholder="Начните вводить город..."
                          OnSelectionChange="OnCitySelected"
                          Style="width: 100%;" />
        </FormItem>
    </Form>
</Modal>

<Modal Title="@($"Изменение баланса — {_balanceUser?.FullName}")"
       Visible="@_balanceModalVisible"
       OnOk="@(async () => await HandleBalanceAsync())"
       OnCancel="@(() => _balanceModalVisible = false)"
       ConfirmLoading="@_balanceLoading">
    @if (_balanceUser is not null)
    {
        <div style="margin-bottom: 16px;">
            <Text>Текущий баланс: </Text>
            <Tag Color="@(_balanceUser.Balance >= 0 ? "green" : "red")" Style="font-size: 16px; font-weight: 600;">
                @_balanceUser.Balance.ToString("N2")
            </Tag>
        </div>
        <Form Model="@_balanceForm" Layout="@FormLayout.Vertical">
            <FormItem Label="Сумма (+ пополнение, - списание)" Required>
                <AntDesign.InputNumber @bind-Value="@_balanceForm.Amount"
                             Style="width: 100%;"
                             Step="100"
                             Min="-1000000"
                             Max="1000000"
                             Placeholder="0.00" />
            </FormItem>
            @if (_balanceError is not null)
            {
                <Alert Type="@AlertType.Error"
                       Message="@_balanceError"
                       ShowIcon="true"
                       Style="margin-bottom: 16px;" />
            }
        </Form>
    }
</Modal>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private IReadOnlyList<UserResponse> _users = Array.Empty<UserResponse>();
    private bool _loading = true;
    private bool _createModalVisible;
    private bool _createLoading;
    private CreateUserForm _newUser = new();

    private bool _balanceModalVisible;
    private bool _balanceLoading;
    private UserResponse? _balanceUser;
    private BalanceForm _balanceForm = new();
    private string? _balanceError;

    private static readonly DateTime DefaultDob = new(1999, 1, 1, 0, 0, 0, DateTimeKind.Utc);

    private readonly List<string> _cityOptions = new()
    {
        "Москва", "Санкт-Петербург", "Новосибирск", "Екатеринбург", "Казань",
        "Нижний Новгород", "Челябинск", "Самара", "Омск", "Ростов-на-Дону",
        "Уфа", "Красноярск", "Воронеж", "Пермь", "Волгоград",
        "Краснодар", "Саратов", "Тюмень", "Тольятти", "Ижевск",
        "Барнаул", "Иркутск", "Хабаровск", "Владивосток", "Махачкала",
        "Томск", "Оренбург", "Кемерово", "Новокузнецк", "Рязань",
        "Астрахань", "Набережные Челны", "Пенза", "Липецк", "Калининград",
        "Тула", "Киров", "Сочи", "Мурманск", "Сургут",
        "Владимир", "Смоленск", "Волжский", "Курган", "Мытищи",
        "Тверь", "Иваново", "Брянск", "Стерлитамак", "Магнитогорск",
        "Ярославль", "Ульяновск", "Орёл", "Кострома", "Нижний Тагил",
        "Петрозаводск", "Владикавказ", "Грозный", "Чита", "Нижневартовск"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        _loading = true;
        try
        {
            _users = await Dispatcher.SendAsync(new GetAllUsersQuery());
        }
        catch (Exception ex)
        {
            await MessageService.Error($"Не удалось загрузить пользователей: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void ShowCreateModal()
    {
        _newUser = new() { DateOfBirth = DefaultDob };
        _createModalVisible = true;
    }

    private void OnCitySelected(object? value)
    {
        if (value is string city)
            _newUser.PlaceOfBirth = city;
    }

    private async Task HandleCreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newUser.FullName)
            || string.IsNullOrWhiteSpace(_newUser.PlaceOfBirth)
            || _newUser.DateOfBirth is null)
        {
            await MessageService.Warning("Заполните все поля.");
            return;
        }

        _createLoading = true;
        try
        {
            await Dispatcher.SendAsync(new CreateUserRequest(
                _newUser.FullName, _newUser.DateOfBirth.Value, _newUser.PlaceOfBirth));
            await MessageService.Success("Пользователь создан.");
            _createModalVisible = false;
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            await MessageService.Error($"Ошибка создания: {ex.Message}");
        }
        finally
        {
            _createLoading = false;
        }
    }

    private void ShowBalanceModal(UserResponse user)
    {
        _balanceUser = user;
        _balanceForm = new BalanceForm { Amount = 0 };
        _balanceError = null;
        _balanceModalVisible = true;
    }

    private async Task HandleBalanceAsync()
    {
        _balanceError = null;

        if (_balanceUser is null) return;

        if (_balanceForm.Amount == 0)
        {
            _balanceError = "Сумма не может быть нулевой.";
            return;
        }

        var newBalance = _balanceUser.Balance + _balanceForm.Amount;
        if (newBalance < 0)
        {
            _balanceError = $"Операция приведёт к отрицательному балансу ({newBalance:N2}). Баланс: {_balanceUser.Balance:N2}, списание: {_balanceForm.Amount:N2}.";
            return;
        }

        if (newBalance > 1_000_000)
        {
            _balanceError = $"Баланс превысит максимум (1 000 000). Текущий: {_balanceUser.Balance:N2}, итого: {newBalance:N2}.";
            return;
        }

        _balanceLoading = true;
        try
        {
            var updated = await Dispatcher.SendAsync(new UpdateBalanceRequest(_balanceUser.Id, _balanceForm.Amount));
            var msg = _balanceForm.Amount > 0
                ? $"Пополнено на {_balanceForm.Amount:N2}. Новый баланс: {updated.Balance:N2}"
                : $"Списано {Math.Abs(_balanceForm.Amount):N2}. Новый баланс: {updated.Balance:N2}";
            await MessageService.Success(msg);
            _balanceModalVisible = false;
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            _balanceError = $"Ошибка: {ex.Message}";
        }
        finally
        {
            _balanceLoading = false;
        }
    }

    private void NavigateToHistory(int userId) => Navigation.NavigateTo($"/balance-history/{userId}");

    private sealed class CreateUserForm
    {
        public string FullName { get; set; } = string.Empty;
        public DateTime? DateOfBirth { get; set; }
        public string PlaceOfBirth { get; set; } = string.Empty;
    }

    private sealed class BalanceForm
    {
        public decimal Amount { get; set; }
    }
}
